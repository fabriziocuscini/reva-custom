    "react-dom": "^19",
    "zod": "^4"
  },
  "devDependencies": {
    "@pandacss/dev": "^1",
    "@reva/panda-preset": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
