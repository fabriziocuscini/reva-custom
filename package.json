{
  "name": "reva",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=@reva/docs...",
    "dev:advisor": "turbo run dev --filter=@reva/advisor-portal...",
    "dev:client": "turbo run dev --filter=@reva/client-portal...",
    "dev:website": "turbo run dev --filter=@reva/website-static...",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "tokens:build": "turbo run tokens:build",
    "tokens:lint": "bun run --filter @reva/tokens tokens:lint",
    "codegen": "turbo run codegen",
    "dev:palette-generator": "cd packages/design-tokens/tools/palette-generator && bun run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "eslint": "^9",
    "postcss": "^8.5.6",
    "postcss-discard-duplicates": "^7.0.2",
    "prettier": "^3",
    "prettier-plugin-organize-imports": "^4",
    "tsdown": "^0.20.3",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  }
}
