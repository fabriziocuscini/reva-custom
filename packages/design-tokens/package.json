{
  "name": "@reva/tokens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run config/lint.ts && bun run config/build.ts",
    "tokens:build": "bun run config/lint.ts && bun run config/build.ts",
    "figma:sync-code": "bun run scripts/figma-sync-code.ts",
    "tokens:watch": "bun run config/watch.ts",
    "tokens:lint": "bun run config/lint.ts",
    "tokens:serve": "portless tokens.revaos bunx serve dist/figma --cors",
    "dev": "bun run tokens:build && (trap 'kill 0' EXIT; bun run tokens:watch & bun run tokens:serve & wait)"
  },
  "exports": {
    "./css/*": "./dist/css/*",
    "./ts/*": "./dist/ts/*",
    "./json-mobile/*": "./dist/json-mobile/*",
    "./panda/tokens": "./dist/panda/tokens.json",
    "./panda/semantic-tokens": "./dist/panda/semantic-tokens.json",
    "./figma/manifest": "./dist/figma/variables-manifest.json",
    "./panda/components/*": "./dist/panda/components/*.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^22",
    "chroma-js": "^3.2.0",
    "style-dictionary": "^4",
    "typescript": "^5"
  }
}
